# ---- Aqualibria Agent Backend ----

# HTTP server
PORT=8787
HOST=0.0.0.0
NODE_ENV=development

# Where the frontend is hosted. Comma-separated for multiple origins.
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

# Public URL of this backend (used in CORS + WS upgrade hints).
PUBLIC_BASE_URL=http://localhost:8787

# ---- AI ----
# Get a key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Default model used by the Master Architect agent. v3 = gemini-2.5-pro.
GEMINI_MODEL=gemini-2.5-pro

# ---- Supabase ----
SUPABASE_URL=
# Service role key — backend only, NEVER ship to frontend.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Firebase Auth (used to verify ID tokens from the frontend) ----
# If unset, the backend falls back to dev-mode token = userId pass-through.
FIREBASE_PROJECT_ID=
# Either a path to a JSON file or the JSON itself in one line.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ---- Sandbox ----
# "docker" (recommended for production) or "local" (dev fallback, uses node-pty).
SANDBOX_MODE=local
# Root dir on the host where per-project workspaces are stored.
WORKSPACE_ROOT=/var/aqualibria/workspaces
# Docker image used to run sandboxed commands.
SANDBOX_IMAGE=node:20-alpine
# Max wall-clock for one command.
SANDBOX_TIMEOUT_MS=120000
# Hard cap on file size written by the agent (bytes).
MAX_FILE_BYTES=1048576

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ---- Logging ----
LOG_LEVEL=info
